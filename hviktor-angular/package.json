{
  "name": "hviktor-angular",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:lib": "ng build hviktor",
    "build:icons": "ng build icons",
    "build:icons:bundle": "npm run build:icons && node ./scripts/build-icons-bundle.js",
    "version:check": "npm view @helsevestikt/hviktor-angular version",
    "version:patch": "cd projects/hviktor && npm version patch --no-git-tag-version",
    "version:icons:patch": "cd projects/icons && npm version patch --no-git-tag-version",
    "publish:lib": "npm run version:patch && npm run build:lib && cd dist/hviktor && npm publish --access public",
    "publish:icons": "npm run version:icons:patch && npm run build:icons:bundle && cd dist/icons && npm publish --access public",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "scaffold": "node ./scripts/scaffold.js",
    "scaffold:demo": "node ./scripts/scaffold-demo.js",
    "generate:examples": "node ./scripts/generate-examples.js",
    "import:nav-icons": "node ./scripts/import-nav-icons-from-svg.js",
    "lint": "eslint . --ext .ts,.html",
    "lint:staged": "eslint --fix --cache --cache-location .cache/eslint/",
    "lint-staged": "lint-staged",
    "format": "prettier --write .",
    "format:staged": "prettier --write --log-level warn",
    "prepare": "cd .. && husky hviktor-angular/.husky"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^21.2.0",
    "@angular/compiler": "^21.2.0",
    "@angular/core": "^21.2.0",
    "@angular/elements": "^21.2.0",
    "@angular/forms": "^21.2.0",
    "@angular/platform-browser": "^21.2.0",
    "@angular/router": "^21.2.0",
    "@digdir/designsystemet-css": "^1.11.1",
    "@floating-ui/dom": "^1.7.5",
    "@helsevestikt/hviktor-angular": "file:dist/hviktor",
    "@u-elements/u-details": "^0.1.5",
    "highlight.js": "^11.11.1",
    "@u-elements/u-tabs": "^0.1.2",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.2.0",
    "@angular/cli": "^21.2.0",
    "@angular/compiler-cli": "^21.2.0",
    "@tailwindcss/postcss": "^4.1.12",
    "angular-eslint": "21.1.0",
    "esbuild": "^0.24.2",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^16.2.7",
    "ng-packagr": "^21.0.1",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.12",
    "typescript": "~5.9.2",
    "typescript-eslint": "8.47.0",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "*.{ts,html,css,md,json}": "npm run -s format:staged --",
    "*.ts": "npm run -s lint:staged --"
  }
}
