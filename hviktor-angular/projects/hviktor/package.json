{
  "name": "@helsevestikt/hviktor-angular",
  "version": "0.0.28",
  "description": "Angular-komponenter basert på Digdir Designsystemet for Helse Vest IKT",
  "keywords": [
    "angular",
    "components",
    "designsystemet",
    "digdir",
    "helse-vest",
    "a11y",
    "wcag",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/HelseVestIKT/hviktor",
    "directory": "hviktor-angular/projects/hviktor"
  },
  "scripts": {
    "build": "tsc -p tsconfig.schematics.json",
    "postbuild": "npx copyfiles schematics/*/schema.json schematics/*/files/** schematics/collection.json schematics/package.json ../../dist/hviktor && node -e \"require('fs').writeFileSync('../../dist/hviktor/.npmignore','')\""
  },
  "peerDependencies": {
    "@angular/common": ">=17.0.0 <22.0.0",
    "@angular/core": ">=17.0.0 <22.0.0"
  },
  "schematics": "./schematics/collection.json",
  "ng-add": {
    "save": "dependencies"
  },
  "dependencies": {
    "@digdir/designsystemet-css": "^1.13.1",
    "@digdir/designsystemet-web": "^1.13.1",
    "@u-elements/u-details": "^0.1.5",
    "@u-elements/u-tabs": "^0.1.2",
    "tslib": "^2.3.0"
  },
  "exports": {
    "./styles.css": "./styles.css"
  },
  "files": [
    "fesm2022/",
    "schematics/",
    "types/",
    "index.d.ts",
    "styles.css",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "sideEffects": [
    "**/*.css"
  ]
}
