{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "HviktorNgAdd",
  "title": "Hviktor ng-add schematic",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "Prosjektet som hviktor skal legges til i.",
      "$default": {
        "$source": "projectName"
      }
    },
    "tailwind": {
      "type": "boolean",
      "description": "Installer og konfigurer Tailwind CSS.",
      "default": true,
      "x-prompt": "Vil du installere Tailwind CSS?"
    },
    "icons": {
      "type": "boolean",
      "description": "Installer @helsevestikt/hviktor-icons.",
      "default": true,
      "x-prompt": "Vil du installere hviktor-icons?"
    }
  },
  "required": []
}
