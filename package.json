{
  "name": "hviktor-demoapp",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "start:fresh": "npm run build:lib && ng serve",
    "build": "ng build",
    "build:lib": "ng build hviktor-lib",
    "build:icons": "cd projects/icons && npm run build",
    "build:icons:bundle": "npm run build:icons && node ./scripts/build-icons-bundle.js",
    "version:check": "npm view @helsevestikt/hviktor-angular version",
    "version:patch": "cd projects/hviktor && npm version patch --no-git-tag-version",
    "version:icons:patch": "cd projects/icons && npm version patch --no-git-tag-version",
    "release": "node ./scripts/release.js",
    "publish:lib": "npm run version:patch && npm run build:lib && cd projects/hviktor && npm run build && cd ../.. && cd dist/hviktor-lib && npm publish --access public",
    "publish:icons": "npm run version:icons:patch && npm run build:icons:bundle && cd projects/icons && npm publish --access public",
    "watch": "ng build --watch --configuration development",
    "test": "ng test hviktor-lib --no-watch",
    "test:watch": "ng test hviktor-lib",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "scaffold": "node ./scripts/scaffold.js",
    "scaffold:demo": "node ./scripts/scaffold-demo.js",
    "generate:examples": "node ./scripts/generate-examples.js",
    "generate:mcp-docs": "node ./scripts/generate-mcp-docs.js",
    "generate:register": "node ./scripts/generate-register-elements.js",
    "import:nav-icons": "node ./scripts/import-nav-icons-from-svg.js",
    "lint": "eslint . --ext .ts,.html",
    "lint:staged": "eslint --fix --cache --cache-location .cache/eslint/",
    "lint-staged": "lint-staged",
    "format": "prettier --write .",
    "format:staged": "prettier --write --log-level warn",
    "prepare": "husky"
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/elements": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@helsevestikt/hviktor-angular": "file:dist/hviktor-lib",
    "@helsevestikt/hviktor-icons": "^0.0.48",
    "highlight.js": "^11.11.1",
    "rxjs": "~7.8.0",
    "tailwindcss": "^4.1.18",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/schematics": "^22.0.2",
    "@angular/build": "^22.0.2",
    "@angular/cli": "^22.0.2",
    "@angular/compiler-cli": "^22.0.2",
    "@axe-core/playwright": "^4.11.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.12",
    "@types/node": "^25.5.0",
    "angular-eslint": "22.0.0",
    "copyfiles": "^2.4.1",
    "esbuild": "^0.25.0",
    "eslint": "^9.39.1",
    "husky": "^9.1.7",
    "jsdom": "^27.1.0",
    "lint-staged": "^16.2.7",
    "ng-packagr": "^22.0.0",
    "postcss": "^8.5.3",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^4.1.12",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.61.1",
    "vitest": "^4.0.8"
  },
  "overrides": {
    "brace-expansion": ">=5.0.5",
    "minimatch": ">=10.0.3"
  },
  "lint-staged": {
    "*.{ts,html,css,md,json}": "npm run -s format:staged --",
    "*.ts": "npm run -s lint:staged --"
  }
}
