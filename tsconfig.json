/* To learn more about Typescript configuration file: https://www.typescriptlang.org/docs/handbook/tsconfig-json.html. */
/* To learn more about Angular compiler options: https://angular.dev/reference/configs/angular-compiler-options. */
{
  "compileOnSave": false,
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@helsevestikt/hviktor": ["./dist/hviktor", "./projects/hviktor/src/public-api"],
      "@helsevestikt/hviktor/*": ["./dist/hviktor/*", "./projects/hviktor/src/*"]
    },
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "preserve"
  },
  "angularCompilerOptions": {
    "enableI18nLegacyMessageIdFormat": false,
    "strictInjectionParameters": true,
    "strictInputAccessModifiers": true,
    "typeCheckHostBindings": true,
    "strictTemplates": true
  },
  "files": [],
  "references": [
    {
      "path": "./tsconfig.app.json"
    },
    {
      "path": "./tsconfig.spec.json"
    },
    {
      "path": "./tsconfig.e2e.json"
    },
    {
      "path": "./projects/hviktor/tsconfig.lib.json"
    },
    {
      "path": "./projects/hviktor/tsconfig.spec.json"
    },
    {
      "path": "./projects/icons/tsconfig.lib.json"
    },
    {
      "path": "./projects/icons/tsconfig.spec.json"
    }
  ]
}
